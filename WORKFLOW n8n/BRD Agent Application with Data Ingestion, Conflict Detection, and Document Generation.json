        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [{\n    \"parts\": [{\n      \"text\": \"Generate a complete Business Requirements Document in Markdown format with the following sections: Executive Summary, Stakeholders, Functional Requirements, Non-Functional Requirements, Conflicts and Open Issues, Timeline, Assumptions, Approval.\\n\\nFunctional Requirements:\\n{{ $json.functional.map((r, i) => `${i+1}. ${r.req_text} (Stakeholder: ${r.stakeholder}, Source: ${r.source})`).join('\\n') }}\\n\\nNon-Functional Requirements:\\n{{ $json.nonFunctional.map((r, i) => `${i+1}. ${r.req_text} (Stakeholder: ${r.stakeholder}, Source: ${r.source})`).join('\\n') }}\\n\\nConflicted Requirements:\\n{{ $json.conflicted.map((r, i) => `${i+1}. ${r.req_text} - Conflict: ${r.conflict_note}`).join('\\n') }}\"\n    }]\n  }]\n}",
        "options": {}
      },
      "id": "0e63d82a-a1cc-4065-a480-9198746c35d6",
      "name": "Call Gemini Generate BRD",
      "type": "n8n-nodes-base.httpRequest",
