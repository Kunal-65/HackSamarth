      "parameters": {
        "jsCode": "const requirements = $input.all();\nconst formatted = requirements.map((req, idx) => `${idx + 1}. [ID: ${req.json.id}] ${req.json.req_text} (Type: ${req.json.req_type})`).join('\\n');\nreturn [{ json: { formatted_list: formatted, requirements: requirements.map(r => r.json) } }];"
      },
