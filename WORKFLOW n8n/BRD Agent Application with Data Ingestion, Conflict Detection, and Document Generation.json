    {
      "parameters": {
        "jsCode": "const requirements = $input.all().map(r => r.json);\nconst functional = requirements.filter(r => r.req_type === 'functional' && !r.has_conflict);\nconst nonFunctional = requirements.filter(r => r.req_type === 'non_functional' && !r.has_conflict);\nconst conflicted = requirements.filter(r => r.has_conflict);\nreturn [{ json: { functional, nonFunctional, conflicted, allRequirements: requirements } }];"
      },
      "id": "647c32bd-a364-428b-aa21-5ea2c92de94d",
      "name": "Separate Requirements",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        704,
        528
      ]
