        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-exp:generateContent?key=AIzaSyAda54mWyV0hvPxgRyWW2Lz3ZmqR7ftVAU",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [{\n    \"parts\": [{\n      \"text\": \"Extract business requirements from the following text and return ONLY a JSON array where each item has: req_text, req_type (functional or non_functional), stakeholder, source. Do not include any markdown formatting or code fences.\\n\\nText: {{ $json.text }}\"\n    }]\n  }]\n}",
        "options": {}
      },
      "id": "ba7f4896-c3f9-4b76-9dc7-ee659fb9517f",
      "name": "Call Gemini Extract Requirements",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        704,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "let responseText = $input.item.json.candidates[0].content.parts[0].text;\nresponseText = responseText.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\nconst requirements = JSON.parse(responseText);\nconst project_id = $('Extract Text').item.json.project_id;\nreturn requirements.map(req => ({ json: { ...req, project_id, has_conflict: false } }));"
      },
