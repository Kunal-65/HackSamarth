        "jsCode": "const text = $input.item.json.body.text;\nconst project_id = $input.item.json.body.project_id;\n\nreturn [{ json: { text, project_id } }];"
      },
      "id": "34b9bb11-1591-4b1e-9c44-6d713298ffc4",
