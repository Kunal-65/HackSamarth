        "jsCode": "let brdMarkdown = $input.item.json.candidates[0].content.parts[0].text;\nbrdMarkdown = brdMarkdown.replace(/```markdown\\n?/g, '').replace(/```\\n?/g, '').trim();\nreturn [{ json: { brd: brdMarkdown } }];"
      },
