        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [{\n    \"parts\": [{\n      \"text\": \"Analyze the following business requirements and find contradictions or conflicts. Return ONLY a JSON array of conflict objects with req_id_a, req_id_b, conflict_reason, severity (low, medium, high). Do not include markdown formatting.\\n\\nRequirements:\\n{{ $json.formatted_list }}\"\n    }]\n  }]\n}",
